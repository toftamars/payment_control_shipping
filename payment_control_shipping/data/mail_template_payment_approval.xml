<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="mail_template_payment_approval_request" model="mail.template">
        <field name="name">Ödeme Kontrolü Onay Talebi</field>
        <field name="model_id" ref="sale.model_sale_order"/>
        <field name="subject">Ödemesiz Sevkiyat Onayı Bekleniyor: {{ object.name }}</field>
        <field name="email_from">{{ (object.company_id.email or user.email_formatted) }}</field>
        <field name="auto_delete" eval="True"/>
        <field name="body_html" type="html">
            <div style="margin:0px;padding:0px;font-size:14px;color:#333333;">
                <p>Merhaba,</p>
                <p>
                    <strong><t t-out="object.name or ''"/></strong> numaralı sipariş
                    için <strong>ödemesiz sevkiyat onayı</strong> talep edildi.
                    Bu siparişin ödemesi/faturası henüz tamamlanmadığı için sevkiyat
                    otomatik olarak durduruldu; <strong>doğrulanabilmesi için
                    onayınız gerekiyor.</strong>
                </p>

                <table cellpadding="6" cellspacing="0"
                       style="border-collapse:collapse;margin:12px 0px;font-size:14px;">
                    <tr>
                        <td style="color:#777;">Sipariş No</td>
                        <td><strong><t t-out="object.name or ''"/></strong></td>
                    </tr>
                    <tr>
                        <td style="color:#777;">Müşteri</td>
                        <td><t t-out="object.partner_id.name or ''"/></td>
                    </tr>
                    <tr>
                        <td style="color:#777;">Sipariş Tutarı</td>
                        <td><strong t-out="format_amount(object.amount_total, object.currency_id)">60,00 ₺</strong></td>
                    </tr>
                    <tr>
                        <td style="color:#777;">Sipariş Tarihi</td>
                        <td><t t-out="format_date(object.date_order) or ''"/></td>
                    </tr>
                    <tr>
                        <td style="color:#777;">Satış Temsilcisi</td>
                        <td><t t-out="object.user_id.name or '-'"/></td>
                    </tr>
                    <tr>
                        <td style="color:#777;">Talep Eden</td>
                        <td><t t-out="user.name or ''"/></td>
                    </tr>
                    <tr>
                        <td style="color:#777;">Depo</td>
                        <td><t t-out="object.warehouse_id.name or '-'"/></td>
                    </tr>
                </table>

                <p>
                    Aşağıdaki bağlantıdan doğrudan siparişe gidip
                    <strong>"Ödeme Onayı Kararı"</strong> ile
                    <strong>Onaylayabilir</strong> veya <strong>Reddedebilirsiniz.</strong>
                    Kararınızda kısa bir <strong>açıklama girmeniz zorunludur</strong> ve
                    verdiğiniz karar (kim, ne zaman, gerekçe) sipariş üzerinde
                    kayıt altına alınır.
                </p>

                <div style="margin:18px 0px;">
                    <a t-att-href="'%s/web#id=%s&amp;model=sale.order&amp;view_type=form' % (object.get_base_url(), object.id)"
                       style="background-color:#875A7B;padding:11px 20px;text-decoration:none;color:#ffffff;border-radius:5px;font-size:14px;display:inline-block;">
                        Siparişi Aç ve Karar Ver
                    </a>
                </div>

                <p style="color:#999;font-size:12px;margin-top:18px;">
                    Bu e-posta, ödeme kontrollü sevkiyat sürecinde onaycı olarak
                    tanımlı olduğunuz için gönderilmiştir. Onaylamanız durumunda bu
                    siparişin sevkiyatı ödemesi tamamlanmadan doğrulanabilecektir.
                </p>
            </div>
        </field>
    </record>
</odoo>
