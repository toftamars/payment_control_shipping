<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_payment_control" model="ir.ui.view">
        <field name="name">res.config.settings.form.payment.control</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="stock.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('settings')]" position="inside">
                <div class="app_settings_block" data-string="Ödeme Kontrolü"
                     string="Ödeme Kontrolü" data-key="payment_control_shipping"
                     groups="base.group_system">
                    <h2>Ödeme Kontrollü Sevkiyat</h2>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="payment_control_enabled"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="payment_control_enabled"/>
                                <div class="text-muted">
                                    Kapatılırsa ödeme/fatura kontrolü tüm
                                    sevkiyatlarda geçici olarak devre dışı kalır
                                    (kriz modu). Onay mekanizması ve engelleme
                                    çalışmaz; tekrar açınca kaldığı yerden devam
                                    eder.
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
