<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_payment_control_approval_wizard_form" model="ir.ui.view">
        <field name="name">payment.control.approval.wizard.form</field>
        <field name="model">payment.control.approval.wizard</field>
        <field name="arch" type="xml">
            <form string="Ödemesiz Sevkiyat Onayı İste">
                <group>
                    <field name="order_id"/>
                    <field name="available_approver_ids" invisible="1"/>
                    <field name="approver_ids" widget="many2many_tags"
                           domain="[('id', 'in', available_approver_ids)]"
                           options="{'no_create': True, 'no_open': True}"/>
                </group>
                <footer>
                    <button name="action_send_request" type="object"
                            string="Gönder" class="btn-primary"/>
                    <button string="İptal" special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
